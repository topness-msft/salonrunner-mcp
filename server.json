{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.topness-msft/salonrunner-mcp",
  "description": "Self-hosted MCP to find, book, and cancel salon appointments via SalonRunner.",
  "version": "0.2.0",
  "repository": {
    "url": "https://github.com/topness-msft/salonrunner-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "salonrunner-mcp",
      "version": "0.2.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "SALONRUNNER_SALON_ID",
          "description": "Your salon's numeric id (from your booking URL)",
          "isRequired": true,
          "isSecret": false,
          "format": "string"
        },
        {
          "name": "SALONRUNNER_USERNAME",
          "description": "Your SalonRunner client login (same as the booking site)",
          "isRequired": true,
          "isSecret": false,
          "format": "string"
        },
        {
          "name": "SALONRUNNER_PASSWORD",
          "description": "Your SalonRunner client password",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "SALONRUNNER_READ_ONLY",
          "description": "Set to 'true' to disable booking/cancelling (read-only)",
          "isRequired": false,
          "isSecret": false,
          "format": "string"
        }
      ]
    }
  ]
}
