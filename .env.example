# ---- SalonRunner account (required) ----
# Your salon's numeric id (from your booking URL: .../customer/login.htm?id=XXXXX)
SALONRUNNER_SALON_ID=21248
# Your client login (the same username/password you use on the booking site)
SALONRUNNER_USERNAME=you@example.com
SALONRUNNER_PASSWORD=your-password
# Optional: your numeric customerId. Auto-discovered from the session if omitted.
# SALONRUNNER_CUSTOMER_ID=

# ---- Behaviour ----
# Salon booking granularity in minutes (SalonRunner default is 15).
SALONRUNNER_SLOT_MINUTES=15
# Set to "true" to disable booking/cancelling (read-only mode) while you try it out.
SALONRUNNER_READ_ONLY=false

# ---- Hosts (only change if SalonRunner moves domains) ----
SALONRUNNER_BASE=https://app.salonrunner.com
SALONRUNNER_API_V2=https://app.rosysalonsoftware.com/api/v2

# ---- Remote / HTTP mode auth gate (required ONLY for `npm run start:http`) ----
# A password you choose. claude.ai will prompt for it when connecting. The server
# refuses to start in HTTP mode without this, so you can't accidentally expose an
# open booking endpoint.
MCP_AUTH_PASSWORD=
# Public base URL of THIS server once deployed (e.g. https://your-app.fly.dev).
PUBLIC_URL=http://localhost:8787
PORT=8787
