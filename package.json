{
  "name": "salonrunner-mcp",
  "version": "0.2.0",
  "mcpName": "io.github.topness-msft/salonrunner-mcp",
  "description": "Self-hosted MCP server for booking salon appointments through SalonRunner / Rosy Salon Software client accounts.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "salonrunner-mcp": "dist/stdio.js"
  },
  "files": [
    "dist",
    "README.md",
    "DISCLAIMER.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/stdio.js",
    "start:http": "node dist/http.js",
    "dev": "tsx watch src/stdio.ts",
    "dev:http": "tsx watch src/http.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
